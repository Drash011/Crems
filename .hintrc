{
  "extends": [
    "development"
  ],
  "hints": {
    "axe/name-role-value": [
      "default",
      {
        "link-name": "off",
        "button-name": "off"
      }
    ],
    "no-inline-styles": "off",
    "detect-css-reflows/composite": "off",
    "detect-css-reflows/paint": "off",
    "axe/text-alternatives": "off",
    "css-prefix-order": "off",
    "axe/forms": "off",
    "compat-api/css": "off",
    "axe/parsing": "off"
  }
}